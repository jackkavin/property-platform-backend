# --- App ---
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
LOG_LEVEL=info

# --- MySQL ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=property_app
DB_PASSWORD=change_me_strong_password
DB_NAME=property_platform
DB_CONNECTION_LIMIT=10

# --- Redis (cache, rate-limit, queues) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# --- Security ---
# Comma separated list of allowed origins for CORS
CORS_ALLOWED_ORIGINS=https://yourdomain.com
# Secret used to verify inbound CRM webhook signatures (HMAC SHA256)
CRM_WEBHOOK_SECRET=change_me_webhook_shared_secret
# General API rate limit (requests per window per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
# Stricter limit specifically for enquiry creation (abuse-prone endpoint)
ENQUIRY_RATE_LIMIT_MAX=5

# --- WordPress Headless CMS (WPGraphQL) ---
WPGRAPHQL_ENDPOINT=https://cms.yourdomain.com/graphql
WPGRAPHQL_CACHE_TTL_SECONDS=300

# --- Email (async worker simulation) ---
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=change_me
SMTP_PASSWORD=change_me
SMTP_FROM="Property Platform <no-reply@yourdomain.com>"
