{
  "name": "property-platform-backend",
  "version": "1.0.0",
  "description": "Scalable backend for a high-traffic property platform (enquiries, CRM webhooks, WPGraphQL CMS integration)",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "worker:dev": "nodemon --exec ts-node src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "start:worker": "node dist/src/worker.js",
    "migrate": "node dist/scripts/migrate.js || ts-node scripts/migrate.ts",
    "lint": "eslint . --ext .ts",
    "test": "jest --runInBand",
    "test:load": "autocannon -c 50 -d 20 -m POST -H \"Content-Type: application/json\" -b @scripts/sample-enquiry.json http://localhost:3000/api/enquiry"
  },
  "dependencies": {
    "bullmq": "^5.7.8",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mysql-session": "^3.0.3",
    "graphql-request": "^6.1.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.1",
    "mysql2": "^3.10.0",
    "rate-limit-redis": "^4.2.0",
    "sanitize-html": "^2.13.0",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/sanitize-html": "^2.11.0",
    "@types/uuid": "^9.0.8",
    "autocannon": "^7.15.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.3",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.x"
  }
}
